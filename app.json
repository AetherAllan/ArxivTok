{
  "expo": {
    "name": "ArxivTok",
    "slug": "arxivtok",
    "orientation": "portrait",
    "icon": "./assets/AndroidLogo.png",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.arxivtok.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B1426",
        "foregroundImage": "./assets/AndroidLogo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/AndroidLogo.png"
    },
    "plugins": [
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/AndroidLogo.png",
          "backgroundColor": "#0B1426",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-secure-store",
      [
        "react-native-enriched-markdown",
        {
          "enableMath": true
        }
      ],
      "./plugins/withAbiSplits"
    ],
    "extra": {
      "eas": {
        "projectId": "b5e2b924-3183-4279-ab5f-ada043a30884"
      }
    }
  }
}
